# Server-only connection to the Riwaq API. Never prefix these with NEXT_PUBLIC_.
RIWAQ_API_URL=http://localhost:3000
# Optional browser-facing URL used only in setup instructions and status text.
RIWAQ_PUBLIC_API_URL=http://localhost:3000
RIWAQ_API_KEY=riwaq_replace_with_the_organization_key
# Same value as the API's ADMIN_TOKEN. Enables organization management.
RIWAQ_ADMIN_TOKEN=

# Protects the dashboard UI and signs its HTTP-only login cookie.
# Generate with: openssl rand -hex 32
RIWAQ_DASHBOARD_TOKEN=replace_with_a_long_random_token
