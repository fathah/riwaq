# Postgres (pgvector). In Docker this points at the `db` service.
DATABASE_URL=postgres://riwaq:riwaq@db:5432/riwaq

# Anthropic Claude — required for chat, memory extraction, topic labels.
ANTHROPIC_API_KEY=

# Voyage AI — required for embeddings (voyage-3, 1024 dims).
EMBEDDINGS_API_KEY=

PORT=3000
