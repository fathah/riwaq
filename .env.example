# Postgres (pgvector). In Docker this points at the `db` service.
DATABASE_URL=postgres://riwaq:riwaq@db:5432/riwaq

# --- LLM providers (an agent picks one via its `provider` field) ---

# Anthropic Claude (provider: "anthropic").
ANTHROPIC_API_KEY=

# Any OpenAI-compatible endpoint (provider: "openai").
# Works with OpenAI, OpenRouter, Groq, Together, local Ollama/vLLM/LM Studio, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Groq:        https://api.groq.com/openai/v1
#   Ollama:      http://localhost:11434/v1

# Deployment-wide LLM defaults. An org can override these (per-org config); an
# agent can override the org. Anything left unset falls back to these.
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=
#   empty → uses the provider's built-in default (claude-haiku-4-5-20251001 / gpt-4o-mini)

# --- Embeddings (Voyage AI, voyage-3, 1024 dims) — required for ingest/chat ---
EMBEDDINGS_API_KEY=

PORT=3000
