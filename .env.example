# Postgres (pgvector). In Docker this points at the `db` service.
DATABASE_URL=postgres://riwaq:riwaq@db:5432/riwaq

# --- LLM providers (an agent picks one via its `provider` field) ---

# Anthropic Claude (provider: "anthropic").
ANTHROPIC_API_KEY=

# Any OpenAI-compatible endpoint (provider: "openai").
# Works with OpenAI, OpenRouter, Groq, Together, local Ollama/vLLM/LM Studio, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Groq:        https://api.groq.com/openai/v1
#   Ollama:      http://localhost:11434/v1

# Deployment-wide LLM defaults. An org can override these (per-org config); an
# agent can override the org. Anything left unset falls back to these.
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=
#   empty → uses the provider's built-in default (claude-haiku-4-5-20251001 / gpt-4o-mini)

# --- Embeddings (pluggable, with an offline fallback) ---
# Provider: voyage | openai | local. If unset: 'voyage' when EMBEDDINGS_API_KEY is
# set, otherwise 'local' (in-process, offline, no key, no extra service).
# EMBEDDINGS_PROVIDER=local
EMBEDDINGS_API_KEY=
# For the 'openai' provider — any /v1/embeddings server (OpenAI, Ollama, LM Studio…):
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# Model override (empty → provider default: voyage-3 / text-embedding-3-small / all-MiniLM-L6-v2)
# EMBEDDINGS_MODEL=
# Vector dimension — MUST match the model. Locked into the DB at first migration.
#   local all-MiniLM-L6-v2 = 384 (default) · voyage-3 = 1024 · openai-3-small via dimensions = any
EMBEDDING_DIM=384

# --- Safety / limits ---
# development | test | production. In production, set LLM_ALLOWED_HOSTS below.
NODE_ENV=development
# SSRF egress control for tenant-supplied LLM/embedding base URLs. Private,
# loopback, link-local and cloud-metadata addresses are ALWAYS blocked. Optionally
# restrict to an explicit provider allowlist (comma-separated hostnames):
# LLM_ALLOWED_HOSTS=api.openai.com,api.anthropic.com,openrouter.ai
# Permit http:// (not just https) for tenant LLM URLs — local dev only.
ALLOW_INSECURE_LLM_URLS=0
# Master key for encrypting tenant LLM API keys at rest (AES-256-GCM). Any string;
# empty → plaintext (dev only). Set a strong random value in production, e.g.
#   openssl rand -hex 32
SECRET_ENCRYPTION_KEY=
# Max request body size in bytes (default 20 MB; must stay above the 15 MB upload cap).
MAX_BODY_BYTES=20971520

# --- Retrieval tuning ---
# Drop retrieved chunks below this cosine similarity (0..1); 0 = keep all.
# Calibrate per embedding model. Off by default so retrieval never regresses.
RETRIEVAL_MIN_SIMILARITY=0
# Cap total characters of retrieved context injected into a prompt.
RETRIEVAL_CHAR_BUDGET=12000

PORT=3000
