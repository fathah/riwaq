# Copy this file to .env.production and replace every change-me value.
# Never commit .env.production.

# Image published by .github/workflows/docker-publish.yml.
RIWAQ_IMAGE=ghcr.io/fathah/rewaq:latest
API_PORT=3000

# Internal PostgreSQL service created by docker-compose.prod.yml.
POSTGRES_USER=riwaq
POSTGRES_PASSWORD=change-me-use-a-long-random-password
POSTGRES_DB=riwaq

# docker-compose.prod.yml overrides these with its internal service URLs. Change them
# to real managed-service URLs when running only the API image with `docker run`.
DATABASE_URL=postgres://riwaq:change-me@db:5432/riwaq
REDIS_URL=redis://dragonfly:6379

# Generate each base64 secret independently with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=change-me-base64-32-byte-key
END_USER_SIGNING_SECRET=change-me-base64-32-byte-key

# Generate with: openssl rand -hex 32
ADMIN_TOKEN=change-me-long-random-admin-token

# Comma-separated outbound LLM provider hostnames allowed in production.
LLM_ALLOWED_HOSTS=api.openai.com,api.anthropic.com

# Configure at least one deployment default, or configure a key per organization.
LLM_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Local embeddings need no API key. The first use downloads the model.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_API_KEY=
EMBEDDING_DIM=384
